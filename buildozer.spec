[app]
title = WiFiHackApp
package.name = wifihack
package.domain = org.test
source.include_exts = py,png,jpg,kv,atlas
version = 1.0
requirements = python3,kivy
orientation = portrait
fullscreen = 0
android.permissions = ACCESS_WIFI_STATE,CHANGE_WIFI_STATE,ACCESS_FINE_LOCATION

[buildozer]
log_level = 2
warn_on_root = 1
